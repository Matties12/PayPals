@page "/shoppinglists/{shoppingListId:int}"
@inject IHttpClientFactory ClientFactory
@rendermode InteractiveServer

<div class="detail-page">

    <div class="page-top">
        <a href="/shoppinglists" class="back-link">
            ← Terug naar boodschappenlijsten
        </a>

        <div class="page-header">
            <div>
                <h3>Detail boodschappenlijst</h3>
                <p>Voeg personen en producten toe, kies een betaler en bereken de verdeling.</p>
            </div>

            
        </div>
    </div>

    <div class="detail-grid">

        <div class="card-box">
            <h4>Personen toevoegen</h4>

            @if (allPersons == null)
            {
                <p class="empty-text">Laden van alle personen...</p>
            }
            else if (!allPersons.Any())
            {
                <p class="empty-text">Geen personen gevonden.</p>
            }
            else
            {
                <table class="table clean-table">
                    <thead>
                        <tr>
                            <th>Naam</th>
                            <th>Actie</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var person in allPersons)
                        {
                            bool zitAlInLijst = persons != null && persons.Any(p => p.personId == person.personId);

                            <tr>
                                <td>@person.name</td>
                                <td>
                                    @if (zitAlInLijst)
                                    {
                                        <span class="badge-pill badge-added">Al toegevoegd</span>
                                    }
                                    else
                                    {
                                        <button class="btn small-add-btn" @onclick="() => AddPersonToList(person.personId)">
                                            Toevoegen
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <div class="card-box">
            <h4>Producten toevoegen</h4>

            @if (allProducts == null)
            {
                <p class="empty-text">Laden van alle producten...</p>
            }
            else if (!allProducts.Any())
            {
                <p class="empty-text">Geen producten gevonden.</p>
            }
            else
            {
                <table class="table clean-table">
                    <thead>
                        <tr>
                            <th>Naam</th>
                            <th>Prijs</th>
                            <th>Alcohol</th>
                            <th>Actie</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in allProducts)
                        {
                            bool zitAlInLijst = products != null && products.Any(p => p.productId == product.productId);

                            <tr>
                                <td>@product.name</td>
                                <td>€ @product.price</td>
                                <td>
                                    <span class="badge-pill @(product.isAlcoholic ? "badge-yes" : "badge-no")">
                                        @(product.isAlcoholic ? "Ja" : "Nee")
                                    </span>
                                </td>
                                <td>
                                    @if (zitAlInLijst)
                                    {
                                        <span class="badge-pill badge-added">Al toegevoegd</span>
                                    }
                                    else
                                    {
                                        <button class="btn small-add-btn" @onclick="() => AddProductToList(product.productId)">
                                            Toevoegen
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

    </div>

    <div class="detail-grid mt-4">

        <div class="card-box">
            <h4>Personen in deze lijst</h4>

            @if (persons == null)
            {
                <p class="empty-text">Laden...</p>
            }
            else if (!persons.Any())
            {
                <p class="empty-text">Er zitten nog geen personen in deze lijst.</p>
            }
            else
            {
                <table class="table clean-table">
                    <thead>
                        <tr>
                            <th>Naam</th>
                            <th>Alcohol</th>
                            <th>Acties</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var person in persons)
                        {
                            <tr>
                                <td>@person.name</td>
                                <td>
                                    <span class="badge-pill @(person.paysForAlcohol ? "badge-yes" : "badge-no")">
                                        @(person.paysForAlcohol ? "Ja" : "Nee")
                                    </span>
                                </td>
                                <td>
                                    <button class="btn toggle-btn me-2" @onclick="() => ToggleAlcohol(person.personId)">
                                        Wijzig alcohol
                                    </button>

                                    <button class="btn delete-btn" @onclick="() => OpenDeletePersonPopup(person.personId)">
                                        Verwijder
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <div class="card-box">
            <h4>Producten in deze lijst</h4>

            @if (!string.IsNullOrWhiteSpace(quantityErrorMessage))
            {
                <div class="message error-message">@quantityErrorMessage</div>
            }

            @if (products == null)
            {
                <p class="empty-text">Laden...</p>
            }
            else if (!products.Any())
            {
                <p class="empty-text">Er zitten nog geen producten in deze lijst.</p>
            }
            else
            {
                <table class="table clean-table">
                    <thead>
                        <tr>
                            <th>Naam</th>
                            <th>Prijs</th>
                            <th>Alcohol</th>
                            <th>Aantal</th>
                            <th>Acties</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in products)
                        {
                            <tr>
                                <td>@product.name</td>
                                <td>€ @product.price</td>
                                <td>
                                    <span class="badge-pill @(product.isAlcoholic ? "badge-yes" : "badge-no")">
                                        @(product.isAlcoholic ? "Ja" : "Nee")
                                    </span>
                                </td>
                                <td>
                                    <input class="form-control quantity-input"
                                           type="number"
                                           min="1"
                                           value="@product.quantity"
                                           @onchange="(e => ChangeQuantity(product.productId, e.Value?.ToString()))" />
                                </td>
                                <td>
                                    <button class="btn delete-btn" @onclick="() => OpenDeleteProductPopup(product.productId)">
                                        Verwijder
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

    </div>

    <div class="detail-grid mt-4">

        <div class="card-box">
            <h4>Betaler kiezen</h4>

            @if (persons == null)
            {
                <p class="empty-text">Laden...</p>
            }
            else if (!persons.Any())
            {
                <p class="empty-text">Voeg eerst personen toe aan deze lijst.</p>
            }
            else
            {
                <table class="table clean-table">
                    <thead>
                        <tr>
                            <th>Naam</th>
                            <th>Betaler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var person in persons)
                        {
                            <tr>
                                <td>@person.name</td>
                                <td>
                                    @if (selectedPayerId == person.personId)
                                    {
                                        <span class="badge-pill badge-payer">Huidige betaler</span>
                                    }
                                    else
                                    {
                                        <button class="btn small-add-btn" @onclick="() => SetPayer(person.personId)">
                                            Kies als betaler
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>

        <div class="card-box">
            <h4>Berekening</h4>

            <button class="btn calculate-btn mb-3" @onclick="LoadCalculation">
                Bereken
            </button>

            @if (calculation == null)
            {
                <p class="empty-text">Klik op bereken om het resultaat te zien.</p>
            }
            else
            {
                <div class="calculation-summary">
                    <p><strong>Totaal:</strong> € @calculation.totalAmount</p>

                    @if (!string.IsNullOrWhiteSpace(calculation.payerName))
                    {
                        <p><strong>Betaler:</strong> @calculation.payerName</p>
                    }
                    else
                    {
                        <p><strong>Betaler:</strong> Nog niet gekozen</p>
                    }
                </div>

                <h5 class="sub-title">Terugbetalingen aan de betaler</h5>

                @if (calculation.repayments == null || !calculation.repayments.Any())
                {
                    <p class="empty-text">Kies eerst een betaler om de terugbetalingen te zien.</p>
                }
                else
                {
                    <table class="table clean-table">
                        <thead>
                            <tr>
                                <th>Wie betaalt?</th>
                                <th>Aan wie?</th>
                                <th>Bedrag</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var repayment in calculation.repayments)
                            {
                                <tr>
                                    <td>@repayment.fromName</td>
                                    <td>@repayment.toName</td>
                                    <td>€ @repayment.amount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
        </div>

    </div>
</div>
@if (showDeleteProductPopup)
{
    <div class="popup-background">
        <div class="popup-box">
            <h5>Product uit lijst verwijderen</h5>
            <p>Ben je zeker dat je dit product uit deze boodschappenlijst wil verwijderen?</p>

            <div class="popup-actions">
                <button class="btn cancel-btn" @onclick="CloseDeleteProductPopup">
                    Terug
                </button>

                <button class="btn confirm-delete-btn" @onclick="ConfirmDeleteProductFromList">
                    Verwijderen
                </button>
            </div>
        </div>
    </div>
}
@if (showDeletePersonPopup)
{
    <div class="popup-background">
        <div class="popup-box">
            <h5>Persoon uit lijst verwijderen</h5>
            <p>Ben je zeker dat je deze persoon uit deze boodschappenlijst wil verwijderen?</p>

            <div class="popup-actions">
                <button class="btn cancel-btn" @onclick="CloseDeletePersonPopup">
                    Terug
                </button>

                <button class="btn confirm-delete-btn" @onclick="ConfirmDeletePersonFromList">
                    Verwijderen
                </button>
            </div>
        </div>
    </div>
}
<style>
