@page "/"
@inject IHttpClientFactory ClientFactory
@rendermode InteractiveServer

<div class="home-page">
    <div class="page-header">
        <div>
            <h3>Overzicht</h3>
            <p>Een snel overzicht van je PayPals gegevens.</p>
        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon purple">☰</div>
            <div>
                <h4>@shoppingListCount</h4>
                <p>Lijsten</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon green">👥</div>
            <div>
                <h4>@personCount</h4>
                <p>Personen</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon orange">🛒</div>
            <div>
                <h4>@productCount</h4>
                <p>Producten</p>
            </div>
        </div>

    </div>

    <div class="home-content">
        <div class="card-box recent-card">
            <div class="card-header-row">
                <h4>Recente lijsten</h4>

                <a href="/shoppinglists" class="view-all-link">
                    Alle lijsten →
                </a>
            </div>

            @if (shoppingLists == null)
            {
                <p class="empty-text">Laden...</p>
            }
            else if (!shoppingLists.Any())
            {
                <p class="empty-text">Er zijn nog geen boodschappenlijsten.</p>
            }
            else
            {
                <div class="recent-list">
                    @foreach (var list in shoppingLists.Take(3))
                    {
                        <div class="recent-item">
                            <div class="recent-icon">🧾</div>

                            <div class="recent-info">
                                <h5>@list.title</h5>
                                <p>Boodschappenlijst</p>
                            </div>

                            <a href="@($"/shoppinglists/{list.shoppingListId}")" class="open-link">
                                Bekijken →
                            </a>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .home-page {
        padding: 10px 8px 40px 8px;
    }

    .page-header {
        margin-bottom: 28px;
    }

        .page-header h3 {
            font-size: 2.4rem;
            font-weight: 800;
            color: #111827;
            margin-bottom: 4px;
        }

        .page-header p {
            color: #6b7280;
            font-size: 1rem;
            margin: 0;
        }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
        margin-bottom: 28px;
    }

    .stat-card {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 24px;
        display: flex;
        align-items: center;
        gap: 18px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    }

        .stat-card h4 {
            font-size: 1.6rem;
            font-weight: 800;
            margin: 0;
            color: #111827;
        }

        .stat-card p {
            margin: 2px 0 0 0;
            color: #6b7280;
            font-weight: 500;
        }

    .stat-icon {
        width: 58px;
        height: 58px;
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        font-weight: 800;
    }

    .purple {
        background: #ede9fe;
        color: #6d28d9;
    }

    .green {
        background: #dcfce7;
        color: #15803d;
    }

    .orange {
        background: #ffedd5;
        color: #ea580c;
    }

    .blue {
        background: #dbeafe;
        color: #2563eb;
    }

    .home-content {
        display: grid;
        grid-template-columns: 1fr;
        gap: 28px;
    }

    .card-box {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 28px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    }

    .card-header-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 18px;
        border-bottom: 1px solid #e5e7eb;
        padding-bottom: 16px;
    }

        .card-header-row h4 {
            font-size: 1.35rem;
            font-weight: 800;
            color: #111827;
            margin: 0;
        }

    .view-all-link {
        color: #6d28d9;
        font-weight: 700;
        text-decoration: none;
    }

        .view-all-link:hover {
            text-decoration: underline;
        }

    .recent-list {
        display: flex;
        flex-direction: column;
    }

    .recent-item {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 18px 0;
        border-bottom: 1px solid #edf2f7;
    }

        .recent-item:last-child {
            border-bottom: none;
        }

    .recent-icon {
        width: 50px;
        height: 50px;
        border-radius: 14px;
        background: #ede9fe;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.35rem;
    }

    .recent-info {
        flex: 1;
    }

        .recent-info h5 {
            font-size: 1.05rem;
            font-weight: 800;
            color: #111827;
            margin: 0 0 4px 0;
        }

        .recent-info p {
            color: #6b7280;
            margin: 0;
            font-size: 0.95rem;
        }

    .open-link {
        color: #6d28d9;
        font-weight: 700;
        text-decoration: none;
        white-space: nowrap;
    }

        .open-link:hover {
            text-decoration: underline;
        }

    .empty-text {
        color: #6b7280;
        margin-bottom: 0;
    }

    @@media (max-width: 1000px) {
        .stats-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (max-width: 650px) {
        .stats-grid {
            grid-template-columns: 1fr;
        }

        .recent-item {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

@code {
    private List<ShoppingList>? shoppingLists;
    private int shoppingListCount;
    private int personCount;
    private int productCount;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadDashboardData();
            StateHasChanged();
        }
    }

    private async Task LoadDashboardData()
    {
        var client = ClientFactory.CreateClient("api");

        shoppingLists = await client.GetFromJsonAsync<List<ShoppingList>>("shoppinglists") ?? new();
        var persons = await client.GetFromJsonAsync<List<Person>>("persons") ?? new();
        var products = await client.GetFromJsonAsync<List<Product>>("products") ?? new();

        shoppingListCount = shoppingLists.Count;
        personCount = persons.Count;
        productCount = products.Count;
    }

    public class ShoppingList
    {
        public int shoppingListId { get; set; }
        public string title { get; set; } = "";
        public int? payerId { get; set; }
    }

    public class Person
    {
        public int personId { get; set; }
        public string name { get; set; } = "";
    }

    public class Product
    {
        public int productId { get; set; }
        public string name { get; set; } = "";
        public decimal price { get; set; }
        public bool isAlcoholic { get; set; }
    }
}