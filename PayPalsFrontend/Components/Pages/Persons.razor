@page "/persons"
@inject IHttpClientFactory ClientFactory
@rendermode InteractiveServer

<div class="persons-page">
    <div class="page-header">
        <div>
            <h3>Personen</h3>
            <p>Beheer hier alle personen die kunnen meedoen aan een kostenverdeling.</p>
        </div>
    </div>

    <div class="persons-grid">
        <div class="card-box form-card">
            <h4>Nieuwe persoon</h4>

            <div class="mb-3">
                <label class="form-label">Naam</label>
                <input class="form-control clean-input" placeholder="Bijvoorbeeld: Mats" @bind="newPerson.name" />
            </div>

            <button class="btn add-btn" @onclick="AddPerson">
                + Toevoegen
            </button>

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <div class="message error-message">@errorMessage</div>
            }

            @if (!string.IsNullOrWhiteSpace(successMessage))
            {
                <div class="message success-message">@successMessage</div>
            }
        </div>

        <div class="card-box table-card">
            <h4>Overzicht personen</h4>

            @if (persons == null)
            {
                <p class="empty-text">Laden...</p>
            }
            else if (!persons.Any())
            {
                <p class="empty-text">Geen personen gevonden.</p>
            }
            else
            {
                <table class="table clean-table">
                    <thead>
                        <tr>
                            <th>Naam</th>
                            <th>Acties</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var person in persons)
                        {
                            <tr>
                                <td>@person.name</td>
                                <td>
                                    <button class="btn delete-btn" @onclick="() => OpenDeletePopup(person.personId)">
                                        Verwijder
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@if (showDeletePopup)
{
    <div class="popup-background">
        <div class="popup-box">
            <h5>Persoon verwijderen</h5>
            <p>Ben je zeker dat je deze persoon wil verwijderen?</p>

            <div class="popup-actions">
                <button class="btn cancel-btn" @onclick="CloseDeletePopup">
                    Terug
                </button>

                <button class="btn confirm-delete-btn" @onclick="ConfirmDeletePerson">
                    Verwijderen
                </button>
            </div>
        </div>
    </div>
}

<style>
    .persons-page {
        padding: 10px 8px 40px 8px;
    }

    .page-header {
        margin-bottom: 28px;
    }

        .page-header h3 {
            font-size: 2.4rem;
            font-weight: 800;
            color: #111827;
            margin-bottom: 4px;
        }

        .page-header p {
            color: #6b7280;
            font-size: 1rem;
            margin: 0;
        }

    .persons-grid {
        display: grid;
        grid-template-columns: 360px 1fr;
        gap: 28px;
        align-items: start;
    }

    .card-box {
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 20px;
        padding: 28px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);
    }

        .card-box h4 {
            font-size: 1.35rem;
            font-weight: 750;
            color: #111827;
            margin-bottom: 24px;
        }

    .clean-input {
        border-radius: 12px;
        padding: 12px 14px;
        border: 1px solid #d1d5db;
    }

        .clean-input:focus {
            border-color: #6d5dfc;
            box-shadow: 0 0 0 0.2rem rgba(109, 93, 252, 0.15);
        }

    .add-btn {
        width: 100%;
        background: linear-gradient(135deg, #6d5dfc, #4f46e5);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px 18px;
        font-weight: 700;
        margin-top: 10px;
    }

        .add-btn:hover {
            color: white;
            opacity: 0.95;
        }

    .message {
        margin-top: 16px;
        padding: 12px 14px;
        border-radius: 12px;
        font-weight: 500;
    }

    .error-message {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fecaca;
    }

    .success-message {
        background: #dcfce7;
        color: #166534;
        border: 1px solid #bbf7d0;
    }

    .clean-table {
        margin-bottom: 0;
    }

        .clean-table thead th {
            background: #f8fafc;
            color: #374151;
            font-weight: 700;
            padding: 16px;
            border-bottom: 1px solid #e5e7eb;
        }

        .clean-table tbody td {
            padding: 18px 16px;
            vertical-align: middle;
            border-bottom: 1px solid #edf2f7;
        }

        .clean-table tbody tr:hover {
            background: #fafafa;
        }

    .delete-btn {
        border: 1px solid #ef4444;
        background: white;
        color: #dc2626;
        border-radius: 10px;
        padding: 8px 16px;
        font-weight: 700;
    }

        .delete-btn:hover {
            background: #dc2626;
            color: white;
        }

    .empty-text {
        color: #6b7280;
        margin-bottom: 0;
    }

    .popup-background {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(15, 23, 42, 0.45);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    .popup-box {
        background: white;
        width: 500px;
        max-width: 90%;
        padding: 34px 40px;
        border-radius: 20px;
        box-shadow: 0 20px 45px rgba(0, 0, 0, 0.25);
        text-align: center;
    }

        .popup-box h5 {
            font-size: 1.6rem;
            font-weight: 800;
            margin-bottom: 14px;
            color: #111827;
        }

        .popup-box p {
            color: #6b7280;
            font-size: 1.05rem;
            margin-bottom: 28px;
        }

    .popup-actions {
        display: flex;
        justify-content: center;
        gap: 14px;
    }

    .cancel-btn {
        background: #f3f4f6;
        color: #374151;
        border-radius: 10px;
        padding: 10px 22px;
        font-weight: 700;
    }

    .confirm-delete-btn {
        background: #dc2626;
        color: white;
        border-radius: 10px;
        padding: 10px 22px;
        font-weight: 700;
    }

    @@media (max-width: 900px) {
        .persons-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

@code {
    private Person newPerson = new Person();
    private List<Person>? persons;

    private string errorMessage = "";
    private string successMessage = "";

    private bool showDeletePopup = false;
    private int personIdToDelete;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadPersons();
            StateHasChanged();
        }
    }

    private async Task LoadPersons()
    {
        var client = ClientFactory.CreateClient("api");
        persons = await client.GetFromJsonAsync<List<Person>>("persons");
    }

    private async Task AddPerson()
    {
        errorMessage = "";
        successMessage = "";

        if (string.IsNullOrWhiteSpace(newPerson.name))
        {
            errorMessage = "Vul een naam in.";
            return;
        }

        var client = ClientFactory.CreateClient("api");

        await client.PostAsJsonAsync("persons", newPerson);

        newPerson = new Person();

        await LoadPersons();

        successMessage = "Persoon is toegevoegd.";
        StateHasChanged();
    }

    private void OpenDeletePopup(int id)
    {
        personIdToDelete = id;
        showDeletePopup = true;
    }

    private void CloseDeletePopup()
    {
        showDeletePopup = false;
    }

    private async Task ConfirmDeletePerson()
    {
        errorMessage = "";
        successMessage = "";

        var client = ClientFactory.CreateClient("api");

        var response = await client.DeleteAsync($"persons/{personIdToDelete}");

        if (response.IsSuccessStatusCode)
        {
            successMessage = "Persoon is verwijderd.";
            await LoadPersons();
        }
        else
        {
            errorMessage = "Er ging iets mis bij het verwijderen.";
        }

        showDeletePopup = false;
        StateHasChanged();
    }

    public class Person
    {
        public int personId { get; set; }
        public string name { get; set; } = "";
    }
}