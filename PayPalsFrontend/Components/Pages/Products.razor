@page "/products"
@inject IHttpClientFactory ClientFactory
@rendermode InteractiveServer

<h3>Producten</h3>

<h4>Nieuw product</h4>

<div class="mb-3">
    <label>Naam</label>
    <input class="form-control" @bind="newProduct.name" />
</div>

<div class="mb-3">
    <label>Prijs</label>
    <input class="form-control" type="number" step="0.01" @bind="newProduct.price" />
</div>

<div class="form-check mb-3">
    <input class="form-check-input" type="checkbox" @bind="newProduct.isAlcoholic" />
    <label class="form-check-label">Alcoholisch</label>
</div>

<button class="btn btn-primary" @onclick="AddProduct">Toevoegen</button>

<hr />

@if (products == null)
{
    <p>Laden...</p>
}
else if (!products.Any())
{
    <p>Geen producten gevonden</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Naam</th>
                <th>Prijs</th>
                <th>Alcohol</th>
                <th>Acties</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in products)
            {
                <tr>
                    <td>@product.name</td>
                    <td>€ @product.price</td>
                    <td>@(product.isAlcoholic ? "Ja" : "Nee")</td>
                    <td>
                        <button class="btn btn-danger" @onclick="() => DeleteProduct(product.productId)">
                            Verwijder
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private Product newProduct = new Product();
    private List<Product>? products;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadProducts();
            StateHasChanged();
        }
    }

    private async Task LoadProducts()
    {
        var client = ClientFactory.CreateClient("api");
        products = await client.GetFromJsonAsync<List<Product>>("products");
    }
    private async Task AddProduct()
    {
        var client = ClientFactory.CreateClient("api");

        await client.PostAsJsonAsync("products", newProduct);

        newProduct = new Product();

        await LoadProducts();
        StateHasChanged();
    }
    private async Task DeleteProduct(int id)
    {
        var client = ClientFactory.CreateClient("api");

        await client.DeleteAsync($"products/{id}");

        await LoadProducts();
        StateHasChanged();
    }

    public class Product
    {
        public int productId { get; set; }
        public string name { get; set; } = "";
        public decimal price { get; set; }
        public bool isAlcoholic { get; set; }
    }
}