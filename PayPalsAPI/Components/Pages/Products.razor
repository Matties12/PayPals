@page "/products"
@using PayPalsAPI.Models
@inject PaypalsDB Db
@rendermode InteractiveServer

<h3>Producten</h3>

<h4>Nieuw product</h4>

<div class="mb-3">
    <label>Naam</label>
    <input class="form-control" @bind="newProduct.Name" />
</div>

<div class="mb-3">
    <label>Prijs</label>
    <input class="form-control" type="number" step="0.01" @bind="newProduct.Price" />
</div>

<div class="form-check mb-3">
    <input class="form-check-input" type="checkbox" @bind="newProduct.IsAlcoholic" />
    <label class="form-check-label">Alcoholisch</label>
</div>

<button class="btn btn-primary" @onclick="AddProduct">Toevoegen</button>



<hr />

@if (products == null)
{
    <p>Laden...</p>
}
else if (!products.Any())
{
    <p>Geen producten gevonden.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Naam</th>
                <th>Prijs</th>
                <th>Alcohol</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in products)
            {
                <tr>
                    <td>@product.Name</td>
                    <td>€ @product.Price</td>
                    <td>@(product.IsAlcoholic ? "Ja" : "Nee")</td>
                    <td>
                        <button class="btn btn-danger" @onclick="() => DeleteProduct(product.ProductId)">
                            Verwijder
                        </button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Product>? products;

    protected override void OnInitialized()
    {
        products = Db.Products.ToList();
    }
    private Product newProduct = new Product();
    private void AddProduct()
    {
        Db.Products.Add(newProduct);
        Db.SaveChanges();

        newProduct = new Product();

        products = Db.Products.ToList();
    }
    private void DeleteProduct(int id)
    {
        var product = Db.Products.FirstOrDefault(p => p.ProductId == id);

        if (product != null)
        {
            Db.Products.Remove(product);
            Db.SaveChanges();

            products = Db.Products.ToList();
        }
    }
}